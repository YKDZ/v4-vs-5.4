# Set this to connect to a real PostgreSQL. If unset, the server falls
# back to an embedded pglite database (useful for local dev and tests).
# DATABASE_URL=postgres://termbase:termbase@localhost:5432/termbase

# Optional: persist the pglite database to disk (defaults to in-memory).
# PGLITE_DATA_DIR=./data/termbase

# API port (defaults to 3000)
# PORT=3000
