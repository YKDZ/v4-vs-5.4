{
  "name": "@termbase/server",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "pnpm --filter @termbase/shared build && tsx watch src/index.ts",
    "build": "pnpm --filter @termbase/shared build && tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "pnpm --filter @termbase/shared build && vitest run",
    "typecheck": "pnpm --filter @termbase/shared build && tsc -p tsconfig.json --noEmit",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.1",
    "@hono/zod-validator": "^0.4.3",
    "@termbase/shared": "workspace:*",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.44.2",
    "fast-xml-parser": "^5.2.5",
    "hono": "^4.7.7",
    "pg": "^8.16.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.2.17",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.15.2",
    "drizzle-kit": "^0.31.1",
    "pg-mem": "^3.0.5",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
